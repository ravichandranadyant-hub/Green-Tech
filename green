<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Green-Tech Cost-Benefit Calculator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --accent: #1D9E75;
    --accent-light: #E1F5EE;
    --accent-dark: #0F6E56;
    --bg: #f7f8f6;
    --card-bg: #ffffff;
    --text: #1a1a18;
    --text-muted: #6b6b67;
    --border: rgba(0,0,0,0.1);
    --surface: #f1f0ea;
    --radius-md: 8px;
    --radius-lg: 12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a;
      --card-bg: #252523;
      --text: #e8e7e2;
      --text-muted: #8a8a86;
      --border: rgba(255,255,255,0.1);
      --surface: #2c2c2a;
      --accent-light: #04342C;
      --accent-dark: #9FE1CB;
    }
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
  header { background: var(--card-bg); border-bottom: 0.5px solid var(--border); padding: 1.25rem 2rem; display: flex; align-items: center; gap: 12px; }
  header .logo { width: 32px; height: 32px; background: var(--accent-light); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  header h1 { font-size: 17px; font-weight: 500; }
  header p { font-size: 13px; color: var(--text-muted); margin-top: 2px; }
  .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
  .layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 20px; align-items: start; }
  .section-label { font-size: 11px; font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase; color: var(--text-muted); margin: 1.5rem 0 0.6rem; }
  .section-label:first-child { margin-top: 0; }
  .card { background: var(--card-bg); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; }
  .metric-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
  .metric { background: var(--surface); border-radius: var(--radius-md); padding: 0.85rem 1rem; }
  .metric-label { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
  .metric-value { font-size: 21px; font-weight: 500; }
  .metric-sub { font-size: 11px; color: var(--text-muted); margin-top: 3px; }
  .field { margin-bottom: 14px; }
  .field:last-child { margin-bottom: 0; }
  .field-header { display: flex; justify-content: space-between; font-size: 13px; color: var(--text-muted); margin-bottom: 7px; }
  .field-header strong { font-weight: 500; color: var(--text); }
  input[type="range"] { width: 100%; accent-color: var(--accent); }
  select, input[type="number"] { width: 100%; padding: 8px 10px; font-size: 14px; border: 0.5px solid var(--border); border-radius: var(--radius-md); background: var(--card-bg); color: var(--text); outline: none; }
  select:focus, input:focus { border-color: var(--accent); }
  .tech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; }
  .tech-btn { padding: 10px 8px; font-size: 13px; border: 0.5px solid var(--border); border-radius: var(--radius-md); background: var(--card-bg); color: var(--text-muted); cursor: pointer; text-align: center; transition: all 0.15s; }
  .tech-btn:hover { border-color: var(--accent); color: var(--accent-dark); }
  .tech-btn.active { background: var(--accent-light); border-color: var(--accent); color: var(--accent-dark); font-weight: 500; }
  .tech-desc { font-size: 12px; color: var(--text-muted); line-height: 1.6; padding-top: 10px; border-top: 0.5px solid var(--border); }
  .divider { border: none; border-top: 0.5px solid var(--border); margin: 14px 0; }
  .bar-track { height: 5px; background: var(--surface); border-radius: 3px; margin-top: 8px; overflow: hidden; }
  .bar-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.5s ease; }
  .roi-big { font-size: 30px; font-weight: 500; color: var(--accent-dark); }
  .chart-wrap { position: relative; width: 100%; height: 210px; }
  .badge { display: inline-block; font-size: 11px; padding: 3px 9px; border-radius: 6px; font-weight: 500; }
  .badge-green { background: var(--accent-light); color: var(--accent-dark); }
  .badge-red { background: #FCEBEB; color: #501313; }
  .badge-amber { background: #FAEEDA; color: #633806; }
  .science-row { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 0.5px solid var(--border); font-size: 13px; }
  .science-row:last-child { border-bottom: none; }
  .sci-note { font-size: 11px; color: var(--text-muted); }
  .timeline-item { display: flex; align-items: center; gap: 10px; padding: 6px 0; font-size: 13px; }
  .t-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .t-dot.future { background: var(--border); }
  .insight { background: var(--accent-light); border-radius: var(--radius-md); padding: 1rem; font-size: 13px; color: var(--accent-dark); line-height: 1.7; margin-top: 12px; }
  .bottom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
  @media (max-width: 768px) {
    .layout, .bottom-grid { grid-template-columns: 1fr; }
    .container { padding: 1rem; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">🌿</div>
  <div>
    <h1>Green-Tech Cost-Benefit Calculator</h1>
    <p>ROI, NPV & payback analysis for solar, heat pumps, and EVs</p>
  </div>
</header>

<div class="container">
  <div class="layout">

    <!-- LEFT COLUMN: Inputs -->
    <div>
      <p class="section-label">Location & Climate</p>
      <div class="card">
        <div class="field">
          <div class="field-header">Climate zone <strong id="zone-label">Moderate</strong></div>
          <select id="climate" onchange="calculate()">
            <option value="high">Sunny (CA, AZ, TX) — 5.5+ sun hrs/day</option>
            <option value="moderate" selected>Moderate (Midwest, SE) — 4–5 hrs/day</option>
            <option value="low">Cloudy (PNW, NE) — 3–4 hrs/day</option>
          </select>
        </div>
        <div class="field">
          <div class="field-header">Electricity rate <strong id="rate-label">$0.14 / kWh</strong></div>
          <input type="range" id="utility-rate" min="0.08" max="0.35" step="0.01" value="0.14" oninput="syncRate(this)">
        </div>
        <div class="field">
          <div class="field-header">Annual rate inflation <strong id="inf-label">3%</strong></div>
          <input type="range" id="inflation" min="1" max="8" step="0.5" value="3" oninput="syncInf(this)">
        </div>
      </div>

      <p class="section-label">Energy Profile</p>
      <div class="card">
        <div class="field">
          <div class="field-header">Monthly electricity use <strong id="kwh-label">900 kWh</strong></div>
          <input type="range" id="usage" min="300" max="3000" step="50" value="900" oninput="syncUsage(this)">
        </div>
        <div class="field">
          <div class="field-header">Home size <strong id="size-label">2,000 sq ft</strong></div>
          <input type="range" id="home-size" min="500" max="6000" step="100" value="2000" oninput="syncSize(this)">
        </div>
      </div>

      <p class="section-label">Technology</p>
      <div class="card">
        <div class="tech-grid">
          <button class="tech-btn active" id="btn-solar" onclick="setTech('solar')">☀ Solar Panels</button>
          <button class="tech-btn" id="btn-hp" onclick="setTech('hp')">🌡 Heat Pump</button>
          <button class="tech-btn" id="btn-ev" onclick="setTech('ev')">⚡ EV + Charger</button>
        </div>
        <div class="tech-desc" id="tech-desc"></div>
        <div class="divider"></div>
        <div class="field">
          <div class="field-header">Federal tax credit / ITC <strong id="sub-label">30%</strong></div>
          <input type="range" id="subsidy" min="0" max="50" step="5" value="30" oninput="syncSub(this)">
        </div>
        <div class="field">
          <div class="field-header">Discount rate (opportunity cost) <strong id="disc-label">6%</strong></div>
          <input type="range" id="discount" min="2" max="12" step="0.5" value="6" oninput="syncDisc(this)">
          <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">This is what you'd earn investing elsewhere — used for NPV calculation.</p>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: Results -->
    <div>
      <p class="section-label" style="margin-top:0">Financial Summary</p>
      <div class="metric-grid">
        <div class="metric">
          <div class="metric-label">Net system cost</div>
          <div class="metric-value" id="net-cost">—</div>
          <div class="metric-sub">after subsidy</div>
        </div>
        <div class="metric">
          <div class="metric-label">Annual savings</div>
          <div class="metric-value" id="annual-save">—</div>
          <div class="metric-sub">year 1</div>
        </div>
        <div class="metric">
          <div class="metric-label">Payback period</div>
          <div class="metric-value" id="payback">—</div>
          <div class="metric-sub">years to break even</div>
        </div>
        <div class="metric">
          <div class="metric-label">25-yr NPV</div>
          <div class="metric-value" id="npv">—</div>
          <div class="metric-sub" id="npv-badge"></div>
        </div>
      </div>

      <div class="card" style="margin-bottom:12px;">
        <div style="font-size:13px;color:var(--text-muted);margin-bottom:6px;">25-year return on investment</div>
        <div class="roi-big" id="roi-pct">—</div>
        <div class="bar-track"><div class="bar-fill" id="roi-bar" style="width:0%"></div></div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:8px;" id="irr-line"></div>
      </div>

      <p class="section-label">Cumulative Savings vs. Cost</p>
      <div class="card" style="margin-bottom:12px;">
        <div class="chart-wrap"><canvas id="savingsChart"></canvas></div>
      </div>

      <p class="section-label">Science Snapshot</p>
      <div class="card">
        <div style="font-size:11px;font-weight:500;color:var(--text-muted);margin-bottom:8px;" id="sci-title"></div>
        <div id="science-box"></div>
      </div>
    </div>
  </div>

  <!-- Bottom: Timeline + Insight -->
  <div class="bottom-grid">
    <div class="card">
      <div style="font-size:11px;font-weight:500;color:var(--text-muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:.06em;">Key Milestones</div>
      <div id="timeline-col"></div>
    </div>
    <div class="card">
      <div style="font-size:11px;font-weight:500;color:var(--text-muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:.06em;">Investment Insight</div>
      <div id="insight-col"></div>
      <div id="co2-box" style="margin-top:12px;font-size:13px;color:var(--text-muted);padding-top:12px;border-top:0.5px solid var(--border);"></div>
    </div>
  </div>
</div>

<script>
let currentTech = 'solar';
let savingsChart = null;

const TECH = {
  solar: {
    name: 'Solar Panels',
    baseCost: 18000,
    scalePer1000sqft: 1200,
    desc: 'Photovoltaic panels convert photons to electrons via the photoelectric effect. Modern mono-Si panels achieve ~20% efficiency. A typical 8 kW system offsets 80–100% of household usage.',
    coveragePct: 0.90,
    scienceTitle: 'Thermodynamics of solar conversion',
    science: [
      { label: 'Panel efficiency', val: '20%', note: 'mono-Si best-in-class' },
      { label: 'Peak sun hours', val: null, note: 'by climate zone' },
      { label: 'Inverter loss', val: '~4%', note: 'DC→AC conversion' },
      { label: 'Temp derating', val: '~0.4%/°C', note: 'above 25°C standard test' },
    ],
    co2: (kwh) => (kwh * 0.9 * 0.386).toFixed(0) + ' kg CO₂ avoided per year'
  },
  hp: {
    name: 'Heat Pump',
    baseCost: 9000,
    scalePer1000sqft: 400,
    desc: 'Heat pumps move thermal energy via a refrigerant cycle — much like a reverse refrigerator. A COP of 3–4 means 3–4× more heat energy delivered per kWh of electricity consumed, beating gas furnaces and resistance heating.',
    coveragePct: 0.45,
    scienceTitle: 'Coefficient of performance (COP)',
    science: [
      { label: 'COP heating', val: '3.5×', note: 'vs. gas furnace AFUE 0.95' },
      { label: 'COP cooling', val: '4.0×', note: 'replaces separate AC' },
      { label: 'Refrigerant', val: 'R-410A', note: 'or newer R-32 / R-290' },
      { label: 'Carnot max COP', val: '~6–8', note: 'theoretical upper limit' },
    ],
    co2: (kwh) => (kwh * 0.45 * 0.5).toFixed(0) + ' kg CO₂ avoided vs. gas heat'
  },
  ev: {
    name: 'EV + Home Charger',
    baseCost: 7500,
    scalePer1000sqft: 0,
    desc: 'A Level 2 home charger (7.2 kW) charges most EVs overnight at ~10% line loss. At $0.14/kWh and 4 mi/kWh, fuel cost is ~$0.035/mile — vs. ~$0.13/mi for a 30 MPG car at $4/gallon gasoline.',
    coveragePct: 0,
    scienceTitle: 'Energy conversion efficiency',
    science: [
      { label: 'EV drivetrain eff.', val: '85–95%', note: 'vs. ICE 20–40%' },
      { label: 'L2 charger loss', val: '~10%', note: 'AC→battery kWh' },
      { label: 'Avg annual miles', val: '12,000', note: 'US household average' },
      { label: 'Fuel equivalent', val: '≈120 MPGe', note: 'EPA rating typical range' },
    ],
    co2: () => '2.7 metric tons CO₂ avoided annually vs. avg ICE car'
  }
};

function fmt(n){ return '$'+Math.round(n).toLocaleString(); }
function fmtK(n){ const a=Math.abs(n); return (n<0?'-':'')+'$'+(a>=1000?(a/1000).toFixed(1)+'k':Math.round(a).toString()); }

function setTech(t){
  currentTech = t;
  ['solar','hp','ev'].forEach(k=>{
    document.getElementById('btn-'+k).classList.toggle('active', k===t);
  });
  document.getElementById('tech-desc').textContent = TECH[t].desc;
  calculate();
}

function syncRate(el){ document.getElementById('rate-label').textContent = '$'+parseFloat(el.value).toFixed(2)+'/kWh'; calculate(); }
function syncInf(el){ document.getElementById('inf-label').textContent = el.value+'%'; calculate(); }
function syncUsage(el){ document.getElementById('kwh-label').textContent = parseInt(el.value).toLocaleString()+' kWh'; calculate(); }
function syncSize(el){ document.getElementById('size-label').textContent = parseInt(el.value).toLocaleString()+' sq ft'; calculate(); }
function syncSub(el){ document.getElementById('sub-label').textContent = el.value+'%'; calculate(); }
function syncDisc(el){ document.getElementById('disc-label').textContent = el.value+'%'; calculate(); }

function calculate(){
  const climate = document.getElementById('climate').value;
  const rate = parseFloat(document.getElementById('utility-rate').value);
  const inflRate = parseFloat(document.getElementById('inflation').value)/100;
  const monthlyKwh = parseFloat(document.getElementById('usage').value);
  const homeSize = parseFloat(document.getElementById('home-size').value);
  const subsidyPct = parseFloat(document.getElementById('subsidy').value)/100;
  const discRate = parseFloat(document.getElementById('discount').value)/100;
  const tech = TECH[currentTech];

  document.getElementById('zone-label').textContent = climate==='high'?'Sunny':climate==='moderate'?'Moderate':'Cloudy';

  const sunHrs = climate==='high'?5.5:climate==='moderate'?4.5:3.5;
  const annualKwh = monthlyKwh * 12;
  const annualBill = annualKwh * rate;

  const grossCost = tech.baseCost + (homeSize/1000)*tech.scalePer1000sqft;
  const netCost = grossCost * (1 - subsidyPct);

  let annualSavings;
  if(currentTech==='solar'){
    annualSavings = annualBill * tech.coveragePct * (sunHrs/4.5);
  } else if(currentTech==='hp'){
    annualSavings = annualBill * 0.40;
  } else {
    const gasCost = 12000/30 * 4.00;
    const evCost = 12000/4 * rate * 1.10;
    annualSavings = Math.max(0, gasCost - evCost);
  }

  const payback = netCost / annualSavings;

  let npv = -netCost;
  let cumul = -netCost;
  let cumulSavings = [];
  for(let y=1; y<=25; y++){
    const savY = annualSavings * Math.pow(1+inflRate, y-1);
    npv += savY / Math.pow(1+discRate, y);
    cumul += savY;
    cumulSavings.push(Math.round(cumul));
  }

  const totalSaved = cumulSavings[24];
  const roi = ((totalSaved) / netCost) * 100;

  document.getElementById('net-cost').textContent = fmt(netCost);
  document.getElementById('annual-save').textContent = fmtK(annualSavings);
  document.getElementById('payback').textContent = payback.toFixed(1)+' yrs';
  document.getElementById('npv').textContent = fmtK(Math.abs(npv));
  document.getElementById('npv-badge').innerHTML = npv>=0
    ? '<span class="badge badge-green">Positive NPV ✓</span>'
    : '<span class="badge badge-red">Negative NPV</span>';

  const roiDisplay = Math.round(roi);
  document.getElementById('roi-pct').textContent = roiDisplay+'% total ROI';
  document.getElementById('roi-bar').style.width = Math.min(100, Math.max(0, roi/4))+'%';
  document.getElementById('irr-line').textContent = '25-year total savings: '+fmt(totalSaved+netCost)+' | Net gain: '+fmtK(totalSaved);

  drawChart(cumulSavings, netCost);
  drawScience(tech, sunHrs);
  drawTimeline(payback, netCost, annualSavings, npv, roi, annualKwh);
}

function drawChart(data, netCost){
  if(savingsChart){ savingsChart.destroy(); savingsChart=null; }
  const labels = Array.from({length:25},(_,i)=>'Y'+(i+1));
  const ctx = document.getElementById('savingsChart').getContext('2d');
  savingsChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Net cumulative value',
          data,
          borderColor: '#1D9E75',
          backgroundColor: 'rgba(29,158,117,0.07)',
          fill: true,
          tension: 0.35,
          pointRadius: 0,
          borderWidth: 2
        },
        {
          label: 'Break-even line',
          data: Array(25).fill(0),
          borderColor: 'rgba(100,100,100,0.35)',
          borderDash: [5,4],
          pointRadius: 0,
          borderWidth: 1,
          fill: false
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          ticks: { font:{size:11}, maxRotation:0, autoSkip:true, maxTicksLimit:10 },
          grid: { display:false }
        },
        y: {
          ticks: {
            font: {size:11},
            callback: v => v>=1000||v<=-1000 ? '$'+(v/1000).toFixed(0)+'k' : '$'+v
          },
          grid: { color:'rgba(128,128,128,0.12)' }
        }
      }
    }
  });
}

function drawScience(tech, sunHrs){
  document.getElementById('sci-title').textContent = tech.scienceTitle;
  const rows = tech.science.map((s,i) => {
    const val = (i===1 && currentTech==='solar') ? sunHrs+' hrs/day' : s.val||'';
    return `<div class="science-row">
      <span style="color:var(--text-muted)">${s.label}</span>
      <span style="font-weight:500">${val} <span class="sci-note">${s.note}</span></span>
    </div>`;
  }).join('');
  document.getElementById('science-box').innerHTML = rows;
}

function drawTimeline(payback, netCost, annualSavings, npv, roi, annualKwh){
  const yr = new Date().getFullYear();
  const beYr = yr + Math.ceil(payback);
  const items = [
    { year: yr, label: 'System installed, subsidy applied', future: false },
    { year: yr+1, label: 'First full year of savings: '+fmtK(annualSavings), future: false },
    { year: beYr, label: 'Break-even reached ✓', future: beYr>yr+1 },
    { year: yr+15, label: 'Halfway through system lifetime', future: true },
    { year: yr+25, label: 'End of analysis period', future: true },
  ];
  document.getElementById('timeline-col').innerHTML = items.map(e=>
    `<div class="timeline-item">
      <div class="t-dot ${e.future?'future':''}"></div>
      <span style="color:var(--text-muted);min-width:46px;font-size:12px;">${e.year}</span>
      <span>${e.label}</span>
    </div>`
  ).join('');

  const verdict = npv>0
    ? `This investment has a <strong>positive net present value</strong>, beating your ${document.getElementById('discount').value}% opportunity cost benchmark. With a ${Math.round(roi)}% total ROI over 25 years, your green-tech investment significantly outperforms keeping the money in a savings account. The higher utility rates rise, the stronger this case becomes.`
    : `At your current discount rate, the NPV is negative — meaning the investment doesn't beat your alternative uses of capital. Consider: higher utility rates, longer time horizon, or a lower discount rate could flip this positive.`;

  document.getElementById('insight-col').innerHTML = `<div class="insight">${verdict}</div>`;
  document.getElementById('co2-box').innerHTML = '🌱 Environmental: ' + TECH[currentTech].co2(annualKwh);
}

// Init
setTech('solar');
</script>
</body>
</html>
